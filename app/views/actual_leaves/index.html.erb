<% content_for :title, "休暇種別入力 | LibShiftAI_Pitat" %>

<style>
  .leave-select {
    appearance: none;
    -webkit-appearance: none;
    border: none;
    background: transparent;
    text-align: center;
    text-align-last: center;
    font-size: 0.85rem;
    font-weight: 600;
    width: 100%;
    cursor: pointer;
    padding: 2px 0;
    color: #374151;
  }
  .leave-select:focus {
    outline: 2px solid #6366f1;
    border-radius: 3px;
  }
  .leave-select option { font-weight: normal; }
</style>

<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="fs-4 fw-bold mb-0">休暇種別入力</h1>
    <%= link_to shifts_path(month: @target_month.strftime("%Y-%m")),
        class: "btn btn-sm btn-outline-secondary rounded-pill" do %>
      <i class="bi bi-arrow-left me-1"></i>シフト表に戻る
    <% end %>
  </div>

  <div class="pitat-card p-3 mb-3 small text-muted">
    <i class="bi bi-info-circle me-1"></i>
    シフト生成後に、各職員の「休み」の種別を入力してください。
    <strong>「休（公休）」はデフォルトのため入力不要です。</strong>
    「年・夏・特・病」は出勤日数にカウントされます。
    空欄または「休」のセルは公休として扱います。
    <div class="mt-2">
      <span class="badge bg-light text-dark border me-1">休</span>公休（入力不要）
      <% ActualLeave::LEAVE_LABELS.each do |type, label| %>
        <span class="badge bg-warning text-dark me-1"><%= ActualLeave::LEAVE_TYPES[type] %></span><%= label %>
      <% end %>
    </div>
  </div>

  <div class="pitat-card p-3 mb-3">
    <%= form_with url: actual_leaves_path, method: :get, class: "d-flex align-items-center gap-2" do |f| %>
      <%= f.month_field :month, value: @target_month.strftime("%Y-%m"), class: "form-control form-control-sm", style: "width: auto;" %>
      <%= f.submit "表示", class: "btn btn-sm btn-outline-secondary rounded-pill px-3" %>
    <% end %>
  </div>

  <% if @open_dates.empty? %>
    <div class="alert alert-warning">この月のシフトデータが見つかりません。</div>
  <% else %>
    <%= form_with url: save_actual_leaves_path(month: @target_month.strftime("%Y-%m")), method: :post do |f| %>
      <div class="pitat-card p-0 overflow-hidden mb-3">
        <div class="table-responsive">
          <table class="table table-bordered table-sm text-center align-middle mb-0" style="width:100%; table-layout:fixed; font-size:0.8rem;">
            <thead class="table-light">
              <tr>
                <th class="text-start ps-3 py-2 text-muted fw-semibold" style="width:120px;">職員名</th>
                <% @all_dates.each do |date| %>
                  <% is_closed_h = @closed_days.key?(date) %>
                  <th class="py-1 fw-semibold <%= is_closed_h ? '' : (date.saturday? || date.sunday? ? 'table-info' : '') %>"
                      style="<%= is_closed_h ? 'background-color:#dee2e6;' : '' %>">
                    <%= date.day %><br>
                    <span class="fw-normal text-muted" style="font-size:0.7rem;"><%= %w[日 月 火 水 木 金 土][date.wday] %></span>
                  </th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% @staffs.each do |staff| %>
                <tr>
                  <td class="text-start ps-3 py-1" style="overflow:hidden;">
                    <div class="fw-semibold" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= staff.name %></div>
                    <div class="text-muted" style="font-size:0.7rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= staff.employment_type.name %></div>
                  </td>
                  <% @all_dates.each do |date| %>
                    <% is_closed_c = @closed_days.key?(date) %>
                    <% if is_closed_c %>
                      <td class="p-0" style="background-color:#e5e7eb; color:#9ca3af; font-size:0.75rem;">閉</td>
                    <% else %>
                      <% shift = @shift_map[[staff.id, date]] %>
                      <% leave = @leave_map[[staff.id, date]] %>
                      <% is_working = shift&.is_working %>
                      <% lr_reason = @leave_requests_map[[staff.id, date]] %>
                      <% is_leave_request = lr_reason.present? %>
                      <%
                        lr_leave_type = { "年休" => "annual", "夏期休暇" => "summer" }[lr_reason]
                        selected_type = leave ? leave.leave_type : lr_leave_type
                        cell_class = if date.saturday?
                          "table-info"
                        elsif date.sunday?
                          "table-danger"
                        elsif is_working
                          "bg-light"
                        end
                        cell_style = (!is_working && is_leave_request) ? "background-color:#FEF3C7;" : nil
                      %>
                      <td class="p-0 <%= cell_class %>" style="<%= cell_style %>">
                        <% if is_working %>
                          <span class="text-success fw-bold">○</span>
                        <% else %>
                          <select name="leaves[<%= staff.id %>][<%= date.strftime('%Y-%m-%d') %>]"
                                  class="leave-select"
                                  title="<%= staff.name %> <%= date.strftime('%-m/%-d') %>">
                            <option value="">休</option>
                            <% ActualLeave::LEAVE_TYPES.each do |type, symbol| %>
                              <option value="<%= type %>" <%= 'selected' if selected_type == type %>><%= symbol %></option>
                            <% end %>
                          </select>
                        <% end %>
                      </td>
                    <% end %>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="text-end">
        <%= f.submit "#{@target_month.strftime('%Y年%-m月')}の休暇種別を保存する",
            class: "btn btn-pitat rounded-pill px-4 fw-semibold",
            data: { turbo_confirm: "#{@target_month.strftime('%Y年%-m月')}の休暇種別を保存しますか？" } %>
      </div>
    <% end %>
  <% end %>
</div>
