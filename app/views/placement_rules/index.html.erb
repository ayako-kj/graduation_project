<% content_for :title, "配置ルール一覧 | LibShiftAI_Pitat" %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fs-4 fw-bold mb-0">配置ルール一覧</h1>
    <%= link_to "＋ ルールを追加する", new_placement_rule_path, class: "btn btn-pitat rounded-pill px-4" %>
  </div>

  <% if @placement_rules.empty? %>
    <div class="pitat-card p-5 text-center text-muted">
      <i class="bi bi-clipboard-check fs-1 d-block mb-3"></i>
      <p class="mb-3">まだ配置ルールが登録されていません。</p>
      <%= link_to "ルールを追加する", new_placement_rule_path, class: "btn btn-pitat rounded-pill px-4" %>
    </div>
  <% else %>
    <div class="pitat-card p-0 overflow-hidden">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4 py-3 text-muted small fw-semibold">ルール内容</th>
            <th class="py-3 text-muted small fw-semibold">種類</th>
            <th class="py-3"></th>
          </tr>
        </thead>
        <tbody>
          <% @placement_rules.each do |rule| %>
            <tr>
              <td class="ps-4 py-3 fw-semibold"><%= rule.display_label %></td>
              <td class="py-3">
                <% case rule.rule_type
                   when "min_count" %>
                  <span class="badge bg-primary bg-opacity-10 text-primary">最低人数</span>
                <% when "at_least_one_of" %>
                  <span class="badge bg-success bg-opacity-10 text-success">いずれか1人以上</span>
                <% when "team_min" %>
                  <span class="badge bg-warning bg-opacity-25 text-dark">チーム合計</span>
                <% end %>
              </td>
              <td class="py-3 pe-4 text-end">
                <%= link_to "編集", edit_placement_rule_path(rule), class: "btn btn-sm btn-outline-secondary rounded-pill px-3 me-1" %>
                <%= link_to "削除", placement_rule_path(rule),
                    data: { turbo_method: :delete, turbo_confirm: "このルールを削除しますか？" },
                    class: "btn btn-sm btn-outline-danger rounded-pill px-3" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
