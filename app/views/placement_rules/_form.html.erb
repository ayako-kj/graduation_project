<% if placement_rule.errors.any? %>
  <div class="alert alert-danger rounded-3 mb-4">
    <p class="fw-semibold mb-2"><i class="bi bi-exclamation-circle me-1"></i>入力内容を確認してください</p>
    <ul class="mb-0 ps-3">
      <% placement_rule.errors.full_messages.each do |msg| %>
        <li class="small"><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: placement_rule do |f| %>

  <div class="mb-3">
    <%= f.label :staff_type_id, class: "form-label fw-semibold small" do %>
      職種<span class="badge bg-danger ms-1" style="font-size:0.7rem;">必須</span>
    <% end %>
    <%= f.select :staff_type_id,
        options_from_collection_for_select(@staff_types, :id, :name, placement_rule.staff_type_id),
        { prompt: "選択してください" },
        { class: "form-select" } %>
  </div>

  <div class="mb-4">
    <%= f.label :min_count, class: "form-label fw-semibold small" do %>
      1日の最低出勤人数<span class="badge bg-danger ms-1" style="font-size:0.7rem;">必須</span>
    <% end %>
    <div class="input-group">
      <%= f.number_field :min_count, class: "form-control", min: 1, placeholder: "例：2" %>
      <span class="input-group-text">名</span>
    </div>
    <div class="form-text text-muted">例：司書は1日に最低2名出勤が必要</div>
  </div>

  <%= f.submit placement_rule.new_record? ? "登録する" : "更新する", class: "btn btn-pitat w-100 rounded-pill py-2 fw-semibold" %>

<% end %>
