<% content_for :title, "配置ルール編集 | LibShiftAI_Pitat" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

      <div class="d-flex align-items-center mb-4">
        <%= link_to placement_rules_path, class: "text-muted text-decoration-none me-3" do %>
          <i class="bi bi-arrow-left"></i>
        <% end %>
        <h1 class="fs-4 fw-bold mb-0">配置ルール編集</h1>
      </div>

      <div class="pitat-card p-4">
        <%= render "form", placement_rule: @placement_rule %>
      </div>

    </div>
  </div>
</div>
