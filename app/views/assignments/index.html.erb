<% content_for :title, "担当一覧 | LibShiftAI_Pitat" %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fs-4 fw-bold mb-0">担当一覧</h1>
    <%= link_to "＋ 担当を追加する", new_assignment_path, class: "btn btn-pitat rounded-pill px-4" %>
  </div>

  <% if @assignments.empty? %>
    <div class="pitat-card p-5 text-center text-muted">
      <i class="bi bi-people fs-1 d-block mb-3"></i>
      <p class="mb-3">まだ担当が登録されていません。</p>
      <%= link_to "担当を追加する", new_assignment_path, class: "btn btn-pitat rounded-pill px-4" %>
    </div>
  <% else %>
    <div class="pitat-card p-0 overflow-hidden">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4 py-3 text-muted small fw-semibold">担当名</th>
            <th class="py-3 text-muted small fw-semibold">会議曜日</th>
            <th class="py-3 text-muted small fw-semibold">担当職員</th>
            <th class="py-3"></th>
          </tr>
        </thead>
        <tbody>
          <% @assignments.each do |assignment| %>
            <tr>
              <td class="ps-4 py-3 fw-semibold"><%= assignment.name %></td>
              <td class="py-3">
                <% if assignment.meeting_wday %>
                  <span class="badge bg-primary bg-opacity-10 text-primary">毎週<%= assignment.meeting_wday_name %></span>
                <% else %>
                  <span class="text-muted small">なし</span>
                <% end %>
              </td>
              <td class="py-3">
                <% if assignment.staffs.any? %>
                  <%= assignment.staffs.map(&:name).join("・") %>
                <% else %>
                  <span class="text-muted small">未設定</span>
                <% end %>
              </td>
              <td class="py-3 pe-4 text-end">
                <%= link_to "編集", edit_assignment_path(assignment), class: "btn btn-sm btn-outline-secondary rounded-pill px-3 me-1" %>
                <%= link_to "削除", assignment_path(assignment),
                    data: { turbo_method: :delete, turbo_confirm: "#{assignment.name}を削除しますか？" },
                    class: "btn btn-sm btn-outline-danger rounded-pill px-3" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
