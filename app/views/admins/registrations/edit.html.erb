<% content_for :title, "アカウント設定 | Pitat" %>

<div class="container py-5" style="max-width: 520px;">
  <h1 class="fs-5 fw-bold mb-4">アカウント設定</h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <% if resource.errors.any? %>
      <div class="alert alert-danger rounded-3 mb-4">
        <p class="fw-semibold mb-2"><i class="bi bi-exclamation-circle me-1"></i>入力内容を確認してください</p>
        <ul class="mb-0 ps-3">
          <% resource.errors.full_messages.each do |msg| %>
            <li class="small"><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# 図書館名・定休曜日 %>
    <div class="pitat-card p-4 mb-4">
      <h2 class="fs-6 fw-bold mb-3">図書館の基本設定</h2>
      <div class="mb-3">
        <%= f.label :library_name, "図書館名", class: "form-label fw-semibold small" %>
        <%= f.text_field :library_name, value: current_library.name, class: "form-control", placeholder: "例：○○市立中央図書館" %>
      </div>
      <div class="mb-0">
        <div class="form-label fw-semibold small">定休曜日</div>
        <div class="form-text mb-2">チェックした曜日が毎週の休館日として扱われます（複数選択可）。</div>
        <div class="d-flex flex-wrap gap-3">
          <% [[0,"日"], [1,"月"], [2,"火"], [3,"水"], [4,"木"], [5,"金"], [6,"土"]].each do |wday, name| %>
            <div class="form-check">
              <input class="form-check-input" type="checkbox"
                     name="admin[closed_wdays][]"
                     value="<%= wday %>"
                     id="closed_wday_<%= wday %>"
                     <%= current_library.closed_wdays_array.include?(wday) ? "checked" : "" %>>
              <label class="form-check-label" for="closed_wday_<%= wday %>"><%= name %>曜</label>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# メールアドレス・パスワード %>
    <div class="pitat-card p-4 mb-4">
      <h2 class="fs-6 fw-bold mb-3">メールアドレス・パスワード</h2>

      <div class="mb-3">
        <%= f.label :email, "メールアドレス", class: "form-label fw-semibold small" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "新しいパスワード", class: "form-label fw-semibold small" %>
        <span class="badge bg-secondary ms-1" style="font-size:0.7rem;">任意</span>
        <% if @minimum_password_length %>
          <div class="form-text"><%= @minimum_password_length %>文字以上</div>
        <% end %>
        <div class="input-group">
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "変更しない場合は空欄", id: "admin_password" %>
          <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('admin_password', this)">
            <i class="bi bi-eye"></i>
          </button>
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "form-label fw-semibold small" %>
        <div class="input-group">
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "変更しない場合は空欄", id: "admin_password_confirmation" %>
          <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('admin_password_confirmation', this)">
            <i class="bi bi-eye"></i>
          </button>
        </div>
      </div>

      <div class="mb-0">
        <%= f.label :current_password, "現在のパスワード", class: "form-label fw-semibold small" %>
        <div class="form-text mb-1">メールアドレスまたはパスワードを変更する場合に必要です</div>
        <div class="input-group">
          <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control", id: "admin_current_password" %>
          <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('admin_current_password', this)">
            <i class="bi bi-eye"></i>
          </button>
        </div>
      </div>

      <script>
        function togglePassword(fieldId, btn) {
          const field = document.getElementById(fieldId);
          const icon = btn.querySelector('i');
          if (field.type === 'password') {
            field.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
          } else {
            field.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
          }
        }
      </script>
    </div>

    <div class="d-grid mb-5">
      <%= f.submit "更新する", class: "btn btn-pitat fw-semibold rounded-pill py-2" %>
    </div>
  <% end %>

  <%# アカウント削除 %>
  <div class="pitat-card p-4 border-danger">
    <h2 class="fs-6 fw-bold mb-2 text-danger">アカウントの削除</h2>
    <p class="small text-muted mb-3">アカウントを削除すると、図書館情報・職員情報・シフトデータなどすべての情報が失われます。この操作は取り消せません。</p>
    <%= button_to "アカウントを削除する",
        registration_path(resource_name),
        method: :delete,
        data: { turbo_confirm: "本当にアカウントを削除しますか？\nすべてのデータが失われます。この操作は取り消せません。" },
        class: "btn btn-outline-danger btn-sm rounded-pill px-4" %>
  </div>
</div>
