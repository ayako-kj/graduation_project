<% content_for :title, "管理者登録 | LibShiftAI_Pitat" %>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
  <div class="pitat-card p-5" style="width: 100%; max-width: 440px;">

    <div class="text-center mb-4">
      <h1 class="pitat-brand fw-bold fs-4">LibShiftAI_Pitat</h1>
      <p class="text-muted small mt-1">管理者アカウント登録</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "admins/shared/error_messages", resource: resource %>

      <div class="mb-3">
        <%= f.label :email, "メールアドレス", class: "form-label fw-semibold small" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "form-control", placeholder: "admin@example.com" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "パスワード", class: "form-label fw-semibold small" %>
        <% if @minimum_password_length %>
          <div class="form-text text-muted mb-1"><%= @minimum_password_length %>文字以上</div>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "form-control", placeholder: "••••••••" %>
      </div>

      <div class="mb-4">
        <%= f.label :password_confirmation, "パスワード（確認）", class: "form-label fw-semibold small" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "form-control", placeholder: "••••••••" %>
      </div>

      <%= f.submit "登録する", class: "btn btn-pitat w-100 rounded-pill py-2 fw-semibold" %>

    <% end %>

    <p class="text-center text-muted small mt-3">
      すでにアカウントをお持ちの方は<%= link_to "ログインはこちら", new_admin_session_path, class: "text-muted" %>
    </p>

  </div>
</div>
