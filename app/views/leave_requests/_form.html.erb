<% if leave_request.errors.any? %>
  <div class="alert alert-danger rounded-3 mb-4">
    <p class="fw-semibold mb-2"><i class="bi bi-exclamation-circle me-1"></i>入力内容を確認してください</p>
    <ul class="mb-0 ps-3">
      <% leave_request.errors.full_messages.each do |msg| %>
        <li class="small"><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: leave_request do |f| %>

  <div class="mb-3">
    <%= f.label :staff_id, class: "form-label fw-semibold small" do %>
      職員<span class="badge bg-danger ms-1" style="font-size:0.7rem;">必須</span>
    <% end %>
    <%= f.select :staff_id,
        options_from_collection_for_select(@staffs, :id, :name, leave_request.staff_id),
        { prompt: "選択してください" },
        { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :date, class: "form-label fw-semibold small" do %>
      日付<span class="badge bg-danger ms-1" style="font-size:0.7rem;">必須</span>
    <% end %>
    <%= f.date_field :date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <label class="form-label fw-semibold small">
      休暇種別<span class="badge bg-danger ms-1" style="font-size:0.7rem;">必須</span>
    </label>
    <div class="d-flex gap-2 flex-wrap">
      <% %w[公休 年休 夏期休暇 病気休暇 特別休暇].each do |type| %>
        <div class="form-check form-check-inline">
          <input class="form-check-input" type="radio" name="leave_request[reason]"
                 id="reason_<%= type %>" value="<%= type %>"
                 <%= 'checked' if (leave_request.reason.presence || "公休") == type %>>
          <label class="form-check-label" for="reason_<%= type %>"><%= type %></label>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mb-4">
    <%= f.label :note, class: "form-label fw-semibold small" do %>
      理由<span class="badge bg-secondary ms-1" style="font-size:0.7rem;">任意</span>
    <% end %>
    <%= f.text_field :note, class: "form-control", placeholder: "例：通院、私用など" %>
  </div>

  <%= f.submit leave_request.new_record? ? "登録する" : "更新する", class: "btn btn-pitat w-100 rounded-pill py-2 fw-semibold" %>

<% end %>
