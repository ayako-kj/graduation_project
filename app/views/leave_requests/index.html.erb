<% content_for :title, "希望休一覧 | LibShiftAI_Pitat" %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="fs-4 fw-bold mb-0">希望休一覧</h1>
    <div class="d-flex gap-2">
      <%= link_to hope_urls_staffs_path, class: "btn btn-outline-secondary rounded-pill px-4" do %>
        <i class="bi bi-link-45deg me-1"></i>URL一覧
      <% end %>
      <%= link_to "＋ 希望休を登録する", new_leave_request_path, class: "btn btn-pitat rounded-pill px-4" %>
    </div>
  </div>

  <%= form_with url: leave_requests_path, method: :get, class: "d-flex align-items-center gap-2 mb-4" do |f| %>
    <%= f.month_field :month, value: @target_month.strftime("%Y-%m"), class: "form-control form-control-sm", style: "max-width: 180px;" %>
    <%= f.submit "表示", class: "btn btn-sm btn-outline-secondary rounded-pill px-3" %>
  <% end %>

  <% if @leave_requests.empty? %>
    <div class="pitat-card p-5 text-center text-muted">
      <i class="bi bi-calendar-x fs-1 d-block mb-3"></i>
      <p class="mb-3">まだ希望休が登録されていません。</p>
      <%= link_to "希望休を登録する", new_leave_request_path, class: "btn btn-pitat rounded-pill px-4" %>
    </div>
  <% else %>
    <div class="pitat-card p-0 overflow-hidden">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4 py-3 text-muted small fw-semibold">日付</th>
            <th class="py-3 text-muted small fw-semibold">職員名</th>
            <th class="py-3 text-muted small fw-semibold">休暇種別</th>
            <th class="py-3 text-muted small fw-semibold">理由</th>
            <th class="py-3"></th>
          </tr>
        </thead>
        <tbody>
          <% @leave_requests.each do |leave_request| %>
            <tr>
              <% lr_type = %w[公休 年休 夏期休暇].include?(leave_request.reason) ? leave_request.reason : "公休" %>
              <% badge_color = { "公休" => "bg-warning text-dark", "年休" => "bg-success", "夏期休暇" => "bg-primary" }[lr_type] %>
              <td class="ps-4 py-3 fw-semibold"><%= leave_request.date.strftime("%Y年%m月%d日") %></td>
              <td class="py-3"><%= leave_request.staff.name %></td>
              <td class="py-3"><span class="badge <%= badge_color %>"><%= lr_type %></span></td>
              <td class="py-3"><%= leave_request.note.presence || "－" %></td>
              <td class="py-3 pe-4 text-end">
                <%= link_to "編集", edit_leave_request_path(leave_request), class: "btn btn-sm btn-outline-secondary rounded-pill px-3 me-1" %>
                <%= link_to "削除", leave_request_path(leave_request),
                    data: { turbo_method: :delete, turbo_confirm: "#{leave_request.staff.name}の#{leave_request.date.strftime("%m月%d日")}の希望休を削除しますか？" },
                    class: "btn btn-sm btn-outline-danger rounded-pill px-3" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
