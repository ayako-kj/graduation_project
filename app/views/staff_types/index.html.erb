<% content_for :title, "職種・雇用形態設定 | Pitat" %>

<div class="container py-5" style="max-width: 760px;">
  <h1 class="fs-4 fw-bold mb-4">職種・雇用形態設定</h1>

  <% if notice %>
    <div class="alert alert-success rounded-3 mb-4"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="alert alert-danger rounded-3 mb-4"><%= alert %></div>
  <% end %>

  <%# ---- 職種 ---- %>
  <div class="pitat-card p-4 mb-4">
    <h2 class="fs-6 fw-bold mb-3">職種</h2>
    <p class="small text-muted mb-3">司書・館長など図書館の職種を設定します。▲▼ボタンで並び順を変更できます。</p>

    <% if @staff_types.any? %>
      <table class="table table-sm align-middle mb-3">
        <tbody>
          <% @staff_types.each_with_index do |st, i| %>
            <tr>
              <td class="fw-semibold"><%= st.name %></td>
              <td class="text-end" style="white-space: nowrap;">
                <%= button_to "▲", move_up_staff_type_path(st), method: :patch,
                    class: "btn btn-sm btn-outline-secondary me-1",
                    form: { class: "d-inline" },
                    disabled: i == 0 %>
                <%= button_to "▼", move_down_staff_type_path(st), method: :patch,
                    class: "btn btn-sm btn-outline-secondary me-1",
                    form: { class: "d-inline" },
                    disabled: i == @staff_types.size - 1 %>
                <%= button_to "削除", staff_type_path(st), method: :delete,
                    class: "btn btn-sm btn-outline-danger",
                    form: { class: "d-inline" },
                    data: { turbo_confirm: "「#{st.name}」を削除しますか？職員に割り当て中の場合は削除できません。" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-muted small mb-3">職種が登録されていません。</p>
    <% end %>

    <%= form_with model: @staff_type, url: staff_types_path, class: "d-flex gap-2 align-items-center" do |f| %>
      <div>
        <% if @staff_type.errors[:name].any? %>
          <div class="text-danger small mb-1"><%= @staff_type.errors[:name].first %></div>
        <% end %>
        <%= f.text_field :name, class: "form-control", placeholder: "例：司書", style: "width: 200px;" %>
      </div>
      <%= f.submit "追加", class: "btn btn-pitat rounded-pill px-3" %>
    <% end %>
  </div>

  <%# ---- 雇用形態 ---- %>
  <div class="pitat-card p-4">
    <h2 class="fs-6 fw-bold mb-1">雇用形態</h2>
    <p class="small text-muted mb-3">雇用形態ごとに1日の勤務時間と市役所換算基準時間を設定します。</p>

    <% if @employment_types.any? %>
      <div class="table-responsive mb-3">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light small">
            <tr>
              <th>名前</th>
              <th class="text-center">正規職員</th>
              <th class="text-center">1日の勤務時間</th>
              <th class="text-center">市役所換算基準時間</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @employment_types.each do |et| %>
              <tr>
                <td class="fw-semibold"><%= et.name %></td>
                <td class="text-center">
                  <%= et.is_regular ? "✓" : "－" %>
                </td>
                <td class="text-center small text-muted"><%= et.daily_work_hours %>h/日</td>
                <td class="text-center small text-muted"><%= et.city_hall_daily_hours %>h/日</td>
                <td class="text-end" style="white-space: nowrap;">
                  <button class="btn btn-sm btn-outline-secondary me-1"
                          type="button"
                          data-bs-toggle="collapse"
                          data-bs-target="#et-edit-<%= et.id %>">編集</button>
                  <%= button_to "削除", employment_type_path(et), method: :delete,
                      class: "btn btn-sm btn-outline-danger",
                      form: { class: "d-inline" },
                      data: { turbo_confirm: "「#{et.name}」を削除しますか？職員に割り当て中の場合は削除できません。" } %>
                </td>
              </tr>
              <tr class="collapse" id="et-edit-<%= et.id %>">
                <td colspan="5" class="bg-light py-3 px-3">
                  <%= form_with model: et, url: employment_type_path(et), method: :patch, class: "row g-2 align-items-end" do |f| %>
                    <div class="col-auto">
                      <%= f.label :name, "名前", class: "form-label small mb-1" %>
                      <%= f.text_field :name, class: "form-control form-control-sm", style: "width: 160px;" %>
                    </div>
                    <div class="col-auto">
                      <%= f.label :daily_work_hours, "1日の勤務時間（h）", class: "form-label small mb-1" %>
                      <%= f.number_field :daily_work_hours, class: "form-control form-control-sm", step: 0.25, min: 1, max: 12, style: "width: 100px;" %>
                    </div>
                    <div class="col-auto">
                      <%= f.label :city_hall_daily_hours, "市役所換算基準（h）", class: "form-label small mb-1" %>
                      <%= f.number_field :city_hall_daily_hours, class: "form-control form-control-sm", step: 0.25, min: 1, max: 12, style: "width: 100px;" %>
                    </div>
                    <div class="col-auto">
                      <div class="form-label small mb-1">正規職員</div>
                      <div class="form-check mt-1">
                        <%= f.check_box :is_regular, class: "form-check-input" %>
                        <%= f.label :is_regular, "正規職員として扱う", class: "form-check-label small" %>
                      </div>
                    </div>
                    <div class="col-auto">
                      <%= f.submit "保存", class: "btn btn-sm btn-pitat rounded-pill px-3" %>
                    </div>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-muted small mb-3">雇用形態が登録されていません。</p>
    <% end %>

    <%= form_with model: @employment_type, url: employment_types_path, class: "d-flex gap-2 align-items-center" do |f| %>
      <div>
        <% if @employment_type.errors[:name].any? %>
          <div class="text-danger small mb-1"><%= @employment_type.errors[:name].first %></div>
        <% end %>
        <%= f.text_field :name, class: "form-control", placeholder: "例：パート職員", style: "width: 200px;" %>
      </div>
      <%= f.submit "追加", class: "btn btn-pitat rounded-pill px-3" %>
    <% end %>
    <p class="small text-muted mt-2 mb-0">追加後に「編集」ボタンで勤務時間を設定してください。</p>
  </div>
</div>
