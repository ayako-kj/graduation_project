<% content_for :title, "シフト表 | LibShiftAI_Pitat" %>

<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h1 class="fs-4 fw-bold mb-0">シフト表　<span class="fs-5 fw-normal text-muted"><%= @target_month.strftime("%Y年%-m月") %></span></h1>

    <div class="d-flex align-items-center gap-3 flex-wrap d-print-none">
      <%# 月選択 %>
      <%= form_with url: shifts_path, method: :get, class: "d-flex align-items-center gap-2" do |f| %>
        <%= f.month_field :month, value: @target_month.strftime("%Y-%m"), class: "form-control form-control-sm" %>
        <%= f.submit "表示", class: "btn btn-sm btn-outline-secondary rounded-pill px-3" %>
      <% end %>

      <%# 臨時休館日設定ボタン %>
      <%= link_to temporary_closed_dates_path(month: @target_month.strftime("%Y-%m")),
          class: "btn btn-outline-secondary rounded-pill px-3 fw-semibold" do %>
        <i class="bi bi-door-closed me-1"></i>臨時休館日
      <% end %>

      <%# シフト生成ボタン %>
      <%= button_to "AIでシフトを生成する",
          generate_shifts_path(month: @target_month.strftime("%Y-%m")),
          method: :post,
          data: { turbo_confirm: "#{@target_month.strftime('%Y年%m月')}のシフトをAIで生成しますか？既存のシフトは上書きされます。" },
          class: "btn btn-pitat rounded-pill px-4 fw-semibold" %>

      <%# 確定・ダウンロード・印刷ボタン %>
      <% if @shift_group %>
        <div class="d-flex gap-2 flex-wrap">
          <%= button_to confirm_shifts_path(month: @target_month.strftime("%Y-%m")),
              method: :post,
              class: "btn btn-success rounded-pill px-4 fw-semibold",
              data: { turbo_confirm: "#{@target_month.strftime('%Y年%m月')}のシフトを確定しますか？" } do %>
            <i class="bi bi-check-circle me-1"></i>シフトを確定する
          <% end %>
          <%= link_to actual_leaves_path(month: @target_month.strftime("%Y-%m")),
              class: "btn btn-outline-secondary rounded-pill px-3 fw-semibold" do %>
            <i class="bi bi-pencil-square me-1"></i>休暇種別入力
          <% end %>
          <%= link_to export_shifts_path(month: @target_month.strftime("%Y-%m")),
              class: "btn btn-outline-success rounded-pill px-4 fw-semibold" do %>
            <i class="bi bi-file-earmark-excel me-1"></i>勤務予定表(Excel)
          <% end %>
          <button type="button" onclick="window.print()" class="btn btn-outline-secondary rounded-pill px-4 fw-semibold">
            <i class="bi bi-printer me-1"></i>印刷する
          </button>
          <%= button_to destroy_group_shifts_path(month: @target_month.strftime("%Y-%m")),
              method: :delete,
              class: "btn btn-outline-danger rounded-pill px-3 fw-semibold",
              data: { turbo_confirm: "#{@target_month.strftime('%Y年%-m月')}の生成データを削除しますか？\nシフト表・確定バックアップがすべて消えます。年間サマリーの手入力データは残ります。" } do %>
            <i class="bi bi-trash me-1"></i>生成データを削除
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="pitat-card p-3 mb-4">
    <div class="d-flex flex-wrap gap-4 align-items-start">
      <div>
        <div class="text-muted small fw-semibold mb-1"><i class="bi bi-calendar-check me-1"></i>月の勤務日数目標</div>
        <div class="small">正規職員：<span class="fw-bold"><%= @working_days[:regular] %>日</span>　会計年度任用職員：<span class="fw-bold"><%= @working_days[:hourly] %>日</span></div>
      </div>
      <div>
        <div class="text-muted small fw-semibold mb-1"><i class="bi bi-door-closed me-1"></i>休館日（<%= @closed_days.size %>日）</div>
        <div class="small text-muted">
          <% @closed_days.each_slice(7) do |slice| %>
            <%= slice.map { |date, label| "#{date.strftime('%-m/%-d')}(#{label})" }.join("　") %><br>
          <% end %>
        </div>
        <% if @temporary_closed_dates_in_month.any? %>
          <div class="mt-1">
            <% @temporary_closed_dates_in_month.each do |date, label| %>
              <span class="badge rounded-pill text-bg-danger me-1" style="font-size:0.7rem;">
                臨時 <%= date.strftime('%-m/%-d') %>（<%= label %>）
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
      <% if @special_date_labels.any? %>
        <div>
          <div class="text-muted small fw-semibold mb-1"><i class="bi bi-star-fill me-1" style="color:#059669;"></i>特定日</div>
          <div class="small">
            <% @special_date_labels.sort.each do |date, labels| %>
              <span class="me-3"><%= date.strftime('%-m/%-d') %>（<span class="fw-semibold"><%= labels.join("・") %></span>）</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# 確定済みバナー %>
  <% if @snapshot %>
    <div class="alert alert-success d-flex align-items-center gap-3 mb-4 py-2 px-3 d-print-none" role="alert">
      <i class="bi bi-check-circle-fill fs-5"></i>
      <div class="small">
        <span class="fw-semibold">確定済み</span>
        <span class="text-muted ms-1">（<%= @snapshot.confirmed_at_jst.strftime('%Y年%-m月%-d日 %H:%M') %>）</span>
        <span class="text-muted">— 誤って再生成しても確定版に戻せます</span>
      </div>
      <%= button_to "確定版から復元",
          restore_shifts_path(month: @target_month.strftime("%Y-%m")),
          method: :post,
          class: "btn btn-sm btn-outline-success rounded-pill ms-auto fw-semibold",
          data: { turbo_confirm: "確定済みのシフトに戻しますか？現在のシフトは上書きされます。" } %>
    </div>
  <% end %>

  <% if @shift_group.nil? %>
    <div class="pitat-card p-5 text-center text-muted">
      <i class="bi bi-calendar2-week fs-1 d-block mb-3"></i>
      <p class="mb-3"><%= @target_month.strftime("%Y年%m月") %>のシフトはまだ生成されていません。</p>
    </div>
  <% else %>
    <div class="mb-3 d-flex gap-3 small flex-wrap align-items-center d-print-none">
      <span><span class="badge bg-success me-1">○</span>出勤</span>
      <span><span class="badge bg-secondary me-1">－</span>休み</span>
      <span><span class="badge bg-danger me-1">!</span>バリデーションエラー</span>
      <span><span class="badge me-1" style="background-color:#adb5bd;">閉</span>休館日</span>
      <span><span class="badge me-1" style="background-color:#f59e0b;">早</span>早番</span>
      <span><span class="badge me-1" style="background-color:#3b82f6;">p</span>ポスト当番</span>
      <span><span class="badge me-1" style="background-color:#ef4444;">P</span>祝日ポスト当番</span>
      <span><span class="badge me-1" style="background-color:#FEF3C7; color:#92400E; border:1px solid #fbbf24;">休</span>公休</span>
      <span><span class="badge me-1" style="background-color:#FEF3C7; color:#92400E; border:1px solid #fbbf24;">年</span>年休</span>
      <span><span class="badge me-1" style="background-color:#FEF3C7; color:#92400E; border:1px solid #fbbf24;">夏</span>夏期休暇</span>
      <span><span class="badge me-1" style="background-color:#D1FAE5; color:#065F46; border:1px solid #6ee7b7;">○</span>特定日・移動図書館・定例会議</span>
      <% if @shift_group&.suppress_all_errors? %>
        <%= button_to restore_errors_shifts_path(month: @target_month.strftime("%Y-%m")),
            method: :post,
            class: "btn btn-sm btn-outline-secondary rounded-pill px-3 ms-auto" do %>
          <i class="bi bi-eye me-1"></i>エラーを再表示
        <% end %>
      <% else %>
        <% has_any_error = @shifts_map.values.any? { |date_map| date_map.values.any? { |s| s.validation_errors.present? } } %>
        <% if has_any_error %>
          <%= button_to suppress_errors_shifts_path(month: @target_month.strftime("%Y-%m")),
              method: :post,
              class: "btn btn-sm btn-outline-danger rounded-pill px-3 ms-auto",
              data: { turbo_confirm: "バリデーションエラーを全て非表示にしますか？" } do %>
            <i class="bi bi-eye-slash me-1"></i>エラーを全て非表示
          <% end %>
        <% end %>
      <% end %>
    </div>

    <div class="table-responsive">
      <table class="table table-bordered table-sm text-center align-middle shift-table" style="font-size: 0.8rem; min-width: 1200px;">
        <thead class="table-light">
          <tr>
            <th class="text-start ps-3 py-2" style="min-width: 120px;">職員名</th>
            <% @dates.each do |date| %>
              <% is_closed = @closed_days.key?(date) %>
              <% sd_labels = @special_date_labels[date] || [] %>
              <% tooltip = [is_closed ? @closed_days[date] : nil, *sd_labels].compact.join(" / ") %>
              <th class="py-2 <%= is_closed ? '' : (date.saturday? || date.sunday? ? 'table-info' : '') %>"
                  style="min-width: 36px; <%= is_closed ? 'background-color:#dee2e6;' : '' %>"
                  <%= tooltip.present? ? "title=\"#{tooltip}\" data-bs-toggle=\"tooltip\" data-bs-placement=\"top\"" : "" %>>
                <div><%= date.day %></div>
                <div class="text-muted" style="font-size: 0.7rem;"><%= %w[日 月 火 水 木 金 土][date.wday] %></div>
                <% if sd_labels.any? %>
                  <div style="font-size: 0.6rem; color: #059669; line-height: 1; margin-top: 1px;">★<%= "×#{sd_labels.size}" if sd_labels.size > 1 %></div>
                <% end %>
              </th>
            <% end %>
            <th class="py-2" style="min-width: 44px;">合計</th>
          </tr>
        </thead>
        <tbody>
          <% @staffs.each do |staff| %>
            <tr>
              <td class="text-start ps-3 fw-semibold"><%= staff.name %><br><span class="text-muted fw-normal" style="font-size: 0.75rem;"><%= staff.staff_type.name %></span></td>
              <% @dates.each do |date| %>
                <% is_closed = @closed_days.key?(date) %>
                <% shift = @shifts_map.dig(staff.id, date) %>
                <% is_holiday_post = shift&.is_holiday_post_duty %>
                <% errors = shift && shift.validation_errors.present? ? JSON.parse(shift.validation_errors) : [] %>
                <% has_error = errors.any? %>
                <% leave_reason = @leave_requests_map[[staff.id, date]] %>
                <% is_leave = leave_reason.present? %>
                <% actual_leave_type = @actual_leave_map[[staff.id, date]] %>
                <% sp = @special_dates_map[date]; is_special = sp == :all || sp&.include?(staff.id) %>
                <% is_mobile = @mobile_library_map[date]&.include?(staff.id) %>
                <% is_assignment = @assignment_map[date]&.include?(staff.id) %>
                <%
                  show_closed = is_closed && !is_holiday_post && !shift&.is_working
                  cell_bg = if show_closed
                    "background-color:#dee2e6;"
                  elsif has_error
                    ""
                  elsif is_holiday_post
                    "background-color:#FEE2E2;"
                  elsif is_leave && shift && !shift.is_working
                    "background-color:#FEF3C7;"
                  elsif (is_special || is_mobile || is_assignment) && shift&.is_working
                    "background-color:#D1FAE5;"
                  end
                %>
                <td class="<%= has_error ? 'table-danger' : '' %> p-0" style="<%= cell_bg %>">
                  <% if shift.nil? %>
                    <span class="text-muted" style="font-size:0.75rem;"><%= is_closed ? '閉' : '－' %></span>
                  <% else %>
                    <div class="shift-cell w-100 d-flex align-items-center justify-content-center"
                         style="min-height:32px; cursor:pointer;"
                         data-shift-id="<%= shift.id %>"
                         data-clickable="true"
                         data-is-closed="<%= show_closed %>"
                         data-staff-name="<%= staff.name %>"
                         data-date="<%= "#{date.strftime('%-m月%-d日（')}#{%w[日 月 火 水 木 金 土][date.wday]}）" %>"
                         data-is-working="<%= shift.is_working %>"
                         data-is-early="<%= shift.is_early %>"
                         data-is-post-duty="<%= shift.is_post_duty %>"
                         data-is-holiday-post-duty="<%= shift.is_holiday_post_duty %>"
                         data-has-error="<%= has_error %>"
                         data-leave-type="<%= actual_leave_type || '' %>">
                      <% if show_closed %>
                        <span class="text-muted" style="font-size:0.75rem;">閉</span>
                      <% elsif shift.is_working %>
                        <% if has_error %>
                          <span class="text-danger fw-bold" title="<%= errors.join("\n") %>" data-bs-toggle="tooltip" data-bs-placement="top">!</span>
                        <% elsif shift.is_early %>
                          <span class="fw-bold" style="color:#d97706;">早</span>
                        <% elsif is_holiday_post %>
                          <span class="fw-bold" style="color:#ef4444;">P</span>
                        <% elsif shift.is_post_duty %>
                          <span class="fw-bold" style="color:#3b82f6;">p</span>
                        <% else %>
                          <span class="text-success fw-bold">○</span>
                        <% end %>
                      <% else %>
                        <% if actual_leave_type %>
                          <span class="fw-bold" style="color:#92400E;"><%= ActualLeave::LEAVE_TYPES[actual_leave_type] %></span>
                        <% elsif is_leave %>
                          <% leave_label = { "公休" => "休", "年休" => "年", "夏期休暇" => "夏", "病気休暇" => "病", "特別休暇" => "特" }[leave_reason] || "休" %>
                          <span class="fw-bold" style="color:#92400E;"><%= leave_label %></span>
                        <% else %>
                          <span class="text-muted">－</span>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </td>
              <% end %>
              <%# 月の出勤日数合計（年休・夏期休暇を含む、祝日ポスト当番は除外） %>
              <% total = @dates.count { |d|
                   shift = @shifts_map.dig(staff.id, d)
                   paid_leave = %w[年休 夏期休暇].include?(@leave_requests_map[[staff.id, d]])
                   (shift&.is_working && !shift.is_holiday_post_duty) || @actual_leave_set.include?([staff.id, d]) || paid_leave
                 } %>
              <td class="fw-semibold"><%= total %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="table-light">
          <tr style="height: 40px;">
            <td class="text-start ps-3 fw-semibold" style="font-size: 0.8rem;">出勤人数</td>
            <% @dates.each do |date| %>
              <% is_closed = @closed_days.key?(date) %>
              <% if is_closed %>
                <td style="background-color:#dee2e6;"></td>
              <% else %>
                <% count = @staffs.count { |s| @shifts_map.dig(s.id, date)&.is_working } %>
                <td class="fw-bold text-success" style="font-size: 0.8rem;"><%= count %></td>
              <% end %>
            <% end %>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  <% end %>
</div>

<%# シフト編集モーダル %>
<div class="modal fade d-print-none" id="shiftEditModal" tabindex="-1" aria-labelledby="shiftEditModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title fw-bold" id="shiftEditModalLabel"></h6>
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
      </div>
      <form id="shiftEditForm" method="post">
        <input type="hidden" name="_method" value="patch">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <div class="modal-body py-3">
          <div class="form-check mb-3">
            <input type="hidden" name="is_working" value="0">
            <input class="form-check-input" type="checkbox" id="editIsWorking" name="is_working" value="1">
            <label class="form-check-label fw-semibold" for="editIsWorking">出勤</label>
          </div>
          <div id="editLeaveTypeSection" class="mb-3" style="display:none;">
            <label class="form-label small fw-semibold mb-1">休暇種別</label>
            <select name="leave_type" class="form-select form-select-sm" id="editLeaveType">
              <option value="">公休（指定なし）</option>
              <option value="annual">年休</option>
              <option value="summer">夏季休暇</option>
              <option value="sick">病気休暇</option>
              <option value="special">特別休暇</option>
            </select>
          </div>
          <div id="editDutyOptions" class="ms-3 d-flex flex-column gap-2">
            <div class="form-check">
              <input type="hidden" name="is_early" value="0">
              <input class="form-check-input" type="checkbox" id="editIsEarly" name="is_early" value="1">
              <label class="form-check-label" for="editIsEarly">早番</label>
            </div>
            <div class="form-check">
              <input type="hidden" name="is_post_duty" value="0">
              <input class="form-check-input" type="checkbox" id="editIsPostDuty" name="is_post_duty" value="1">
              <label class="form-check-label" for="editIsPostDuty">ポスト当番</label>
            </div>
            <div class="form-check">
              <input type="hidden" name="is_holiday_post_duty" value="0">
              <input class="form-check-input" type="checkbox" id="editIsHolidayPostDuty" name="is_holiday_post_duty" value="1">
              <label class="form-check-label" for="editIsHolidayPostDuty">祝日ポスト当番</label>
            </div>
          </div>
        </div>
        <div class="modal-footer py-2">
          <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3" data-bs-dismiss="modal">キャンセル</button>
          <button type="submit" class="btn btn-pitat btn-sm rounded-pill px-3 fw-semibold">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  (function () {
    function initTooltips() {
      document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
        bootstrap.Tooltip.getOrCreateInstance(el);
      });
    }

    function updateDutyOptions(isWorking) {
      var options = document.getElementById('editDutyOptions');
      options.querySelectorAll('input[type="checkbox"]').forEach(function (cb) { cb.disabled = !isWorking; });
      options.style.opacity = isWorking ? '1' : '0.4';
    }

    function updateLeaveTypeSection(isWorking) {
      document.getElementById('editLeaveTypeSection').style.display = isWorking ? 'none' : 'block';
    }

    function openShiftModal(el) {
      var d = el.dataset;
      var closedBadge = d.isClosed === 'true'
        ? ' <span class="badge bg-secondary ms-1" style="font-size:0.7rem;">閉館日</span>' : '';
      document.getElementById('shiftEditModalLabel').innerHTML = d.staffName + '　' + d.date + closedBadge;
      document.getElementById('shiftEditForm').action = '/shifts/' + d.shiftId;

      var isWorking = d.isWorking === 'true';
      document.getElementById('editIsWorking').checked         = isWorking;
      document.getElementById('editIsEarly').checked           = d.isEarly === 'true';
      document.getElementById('editIsPostDuty').checked        = d.isPostDuty === 'true';
      document.getElementById('editIsHolidayPostDuty').checked = d.isHolidayPostDuty === 'true';
      document.getElementById('editLeaveType').value           = d.leaveType || '';
      updateDutyOptions(isWorking);
      updateLeaveTypeSection(isWorking);

      bootstrap.Modal.getOrCreateInstance(document.getElementById('shiftEditModal')).show();
    }

    // イベント委任：古いハンドラを除去して毎回登録し直す（Turbo 対応）
    if (window.__shiftClickHandler) {
      document.removeEventListener('click', window.__shiftClickHandler);
    }
    if (window.__shiftChangeHandler) {
      document.removeEventListener('change', window.__shiftChangeHandler);
    }

    window.__shiftClickHandler = function (e) {
      var cell = e.target.closest('.shift-cell');
      if (!cell || cell.dataset.clickable !== 'true') return;
      openShiftModal(cell);
    };

    window.__shiftChangeHandler = function (e) {
      if (e.target.id !== 'editIsWorking') return;
      if (!e.target.checked) {
        ['editIsEarly', 'editIsPostDuty', 'editIsHolidayPostDuty'].forEach(function (id) {
          document.getElementById(id).checked = false;
        });
      }
      updateDutyOptions(e.target.checked);
      updateLeaveTypeSection(e.target.checked);
    };

    document.addEventListener('click', window.__shiftClickHandler);
    document.addEventListener('change', window.__shiftChangeHandler);

    document.addEventListener('DOMContentLoaded', initTooltips);
    document.addEventListener('turbo:load', initTooltips);
  }());
</script>
