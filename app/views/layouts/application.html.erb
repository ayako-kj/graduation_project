<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "LibShiftAI_Pitat" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="pitat-bg">
    <nav class="navbar navbar-expand-lg pitat-bg border-bottom border-light">
      <div class="container">
        <a class="navbar-brand pitat-brand fw-bold fs-5" href="<%= root_path %>">LibShiftAI_Pitat</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <% if admin_signed_in? %>
            <ul class="navbar-nav me-auto ms-4 gap-1">
              <li class="nav-item">
                <%= link_to "シフト表", shifts_path, class: "nav-link px-3 rounded-pill #{controller_name == 'shifts' ? 'fw-bold pitat-brand' : 'text-muted'}" %>
              </li>
              <li class="nav-item">
                <%= link_to "職員管理", staffs_path, class: "nav-link px-3 rounded-pill #{controller_name == 'staffs' ? 'fw-bold pitat-brand' : 'text-muted'}" %>
              </li>
              <li class="nav-item">
                <%= link_to "年間サマリー", working_day_summaries_path, class: "nav-link px-3 rounded-pill #{controller_name == 'working_day_summaries' ? 'fw-bold pitat-brand' : 'text-muted'}" %>
              </li>
              <li class="nav-item dropdown">
                <a class="nav-link px-3 rounded-pill text-muted dropdown-toggle" href="#" data-bs-toggle="dropdown">マスタ設定</a>
                <ul class="dropdown-menu">
                  <li><%= link_to "配置ルール", placement_rules_path, class: "dropdown-item" %></li>
                  <li><%= link_to "特定日", special_dates_path, class: "dropdown-item" %></li>
                  <li><%= link_to "希望休", leave_requests_path, class: "dropdown-item" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to "勤務実績の手入力", workday_manual_entries_path, class: "dropdown-item" %></li>
                </ul>
              </li>
            </ul>
          <% end %>
          <div class="ms-auto d-flex align-items-center gap-2">
            <% if admin_signed_in? %>
              <%= link_to "ログアウト", destroy_admin_session_path, data: { turbo_method: :delete }, class: "btn btn-pitat-outline rounded-pill px-4" %>
              <i class="bi bi-person-circle fs-4 pitat-brand"></i>
            <% else %>
              <%= link_to "ログイン", new_admin_session_path, class: "btn btn-pitat-outline rounded-pill px-4" %>
              <i class="bi bi-person-circle fs-4 text-secondary"></i>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
        <%= notice %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    <% if alert %>
      <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
        <%= alert %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <footer class="pitat-footer py-4 mt-5 border-top border-light">
      <div class="container text-center">
        <p class="fw-semibold mb-2">LibShiftAI_Pitat</p>
        <div class="d-flex justify-content-center gap-4 mb-3">
          <%= link_to "プライバシーポリシー", privacy_policy_path, class: "text-muted small text-decoration-none" %>
          <%= link_to "ヘルプセンター", help_path, class: "text-muted small text-decoration-none" %>
          <%= link_to "利用規約", terms_path, class: "text-muted small text-decoration-none" %>
        </div>
        <p class="text-muted small mb-0">&copy;<%= Date.today.year %> LibShiftAI Pitat. Public Library Systems.</p>
      </div>
    </footer>
  </body>
</html>
