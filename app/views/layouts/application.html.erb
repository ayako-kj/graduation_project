<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "LibShiftAI_Pitat" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="pitat-bg">
    <nav class="navbar navbar-expand-lg pitat-bg border-bottom border-light">
      <div class="container">
        <a class="navbar-brand pitat-brand fw-bold fs-5" href="<%= root_path %>">LibShiftAI_Pitat</a>
        <div class="ms-auto d-flex align-items-center gap-2">
          <% if admin_signed_in? %>
            <%= link_to "ログアウト", destroy_admin_session_path, data: { turbo_method: :delete }, class: "btn btn-pitat-outline rounded-pill px-4" %>
            <i class="bi bi-person-circle fs-4 pitat-brand"></i>
          <% else %>
            <%= link_to "ログイン", new_admin_session_path, class: "btn btn-pitat-outline rounded-pill px-4" %>
            <i class="bi bi-person-circle fs-4 text-secondary"></i>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
        <%= notice %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    <% if alert %>
      <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
        <%= alert %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <footer class="pitat-footer py-4 mt-5 border-top border-light">
      <div class="container text-center">
        <p class="fw-semibold mb-2">LibShiftAI_Pitat</p>
        <div class="d-flex justify-content-center gap-4 mb-3">
          <a href="#" class="text-muted small text-decoration-none">プライバシーポリシー</a>
          <a href="#" class="text-muted small text-decoration-none">ヘルプセンター</a>
          <a href="#" class="text-muted small text-decoration-none">利用規約</a>
        </div>
        <p class="text-muted small mb-0">&copy;2024 LibShiftAI Pitat. Public Library Systems.</p>
      </div>
    </footer>
  </body>
</html>
