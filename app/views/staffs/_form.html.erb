<% if staff.errors.any? %>
  <div class="alert alert-danger rounded-3 mb-4">
    <p class="fw-semibold mb-2"><i class="bi bi-exclamation-circle me-1"></i>入力内容を確認してください</p>
    <ul class="mb-0 ps-3">
      <% staff.errors.full_messages.each do |msg| %>
        <li class="small"><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: staff do |f| %>

  <div class="mb-3">
    <%= f.label :name, "氏名", class: "form-label fw-semibold small" %>
    <%= f.text_field :name, class: "form-control", placeholder: "例：山田 花子" %>
  </div>

  <div class="mb-3">
    <%= f.label :staff_type_id, "職種", class: "form-label fw-semibold small" %>
    <%= f.select :staff_type_id,
        options_from_collection_for_select(@staff_types, :id, :name, staff.staff_type_id),
        { prompt: "選択してください" },
        { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :employment_type_id, "雇用形態", class: "form-label fw-semibold small" %>
    <%= f.select :employment_type_id,
        options_from_collection_for_select(@employment_types, :id, :name, staff.employment_type_id),
        { prompt: "選択してください" },
        { class: "form-select" } %>
  </div>

  <div class="mb-4">
    <%= f.label :weekly_work_days, "週勤務日数", class: "form-label fw-semibold small" %>
    <div class="input-group">
      <%= f.number_field :weekly_work_days, class: "form-control", min: 1, max: 7, placeholder: "例：5" %>
      <span class="input-group-text">日</span>
    </div>
  </div>

  <%= f.submit staff.new_record? ? "登録する" : "更新する", class: "btn btn-pitat w-100 rounded-pill py-2 fw-semibold" %>

<% end %>
