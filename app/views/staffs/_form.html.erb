<% if staff.errors.any? %>
  <div class="alert alert-danger rounded-3 mb-4">
    <p class="fw-semibold mb-2"><i class="bi bi-exclamation-circle me-1"></i>入力内容を確認してください</p>
    <ul class="mb-0 ps-3">
      <% staff.errors.full_messages.each do |msg| %>
        <li class="small"><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: staff do |f| %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label fw-semibold small" do %>
      氏名<span class="badge bg-danger ms-1" style="font-size:0.7rem;">必須</span>
    <% end %>
    <%= f.text_field :name, class: "form-control", placeholder: "例：山田 花子" %>
  </div>

  <div class="mb-3">
    <%= f.label :employment_type_id, class: "form-label fw-semibold small" do %>
      雇用形態<span class="badge bg-danger ms-1" style="font-size:0.7rem;">必須</span>
    <% end %>
    <%= f.select :employment_type_id,
        options_from_collection_for_select(@employment_types, :id, :name, staff.employment_type_id),
        { prompt: "選択してください" },
        { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :staff_type_id, class: "form-label fw-semibold small" do %>
      職種<span class="badge bg-danger ms-1" style="font-size:0.7rem;">必須</span>
    <% end %>
    <%= f.select :staff_type_id,
        options_from_collection_for_select(@staff_types, :id, :name, staff.staff_type_id),
        { prompt: "選択してください" },
        { class: "form-select" } %>
  </div>

  <% if @assignments.any? %>
  <div class="mb-3">
    <label class="form-label fw-semibold small">
      担当<span class="badge bg-secondary ms-1" style="font-size:0.7rem;">任意</span>
    </label>
    <div class="border rounded-3 p-3">
      <% @assignments.each do |assignment| %>
        <div class="form-check">
          <input type="checkbox" class="form-check-input"
                 name="staff[assignment_ids][]"
                 value="<%= assignment.id %>"
                 id="assignment_<%= assignment.id %>"
                 <%= "checked" if staff.assignments.include?(assignment) %>>
          <label class="form-check-label" for="assignment_<%= assignment.id %>">
            <%= assignment.name %>
            <% if assignment.meeting_wday %>
              <span class="text-muted small">（毎週<%= assignment.meeting_wday_name %>会議）</span>
            <% end %>
          </label>
        </div>
      <% end %>
    </div>
  </div>
  <% end %>

  <div class="mb-3">
    <label class="form-label fw-semibold small">
      基本的に出勤しない曜日<span class="badge bg-secondary ms-1" style="font-size:0.7rem;">任意</span>
    </label>
    <div class="text-muted small mb-2">月に1回程度の例外出勤は考慮されます。</div>
    <div class="d-flex flex-wrap gap-2">
      <% [["日", 0], ["月", 1], ["火", 2], ["水", 3], ["木", 4], ["金", 5], ["土", 6]].each do |label, wday| %>
        <div class="form-check form-check-inline">
          <input type="checkbox"
                 class="form-check-input"
                 name="staff[unavailable_wdays][]"
                 value="<%= wday %>"
                 id="unavailable_wday_<%= wday %>"
                 <%= "checked" if staff.unavailable_wdays_array.include?(wday) %>>
          <label class="form-check-label" for="unavailable_wday_<%= wday %>"><%= label %>曜</label>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :weekly_work_days, class: "form-label fw-semibold small" do %>
      週勤務日数<span class="badge bg-secondary ms-1" style="font-size:0.7rem;">任意</span>
    <% end %>
    <div class="input-group" style="max-width: 180px;">
      <%= f.number_field :weekly_work_days, class: "form-control", min: 1, max: 7, placeholder: "例：5" %>
      <span class="input-group-text">日</span>
    </div>
  </div>

  <div class="mb-4">
    <%= f.label :daily_work_hours, class: "form-label fw-semibold small" do %>
      1日の勤務時間<span class="badge bg-secondary ms-1" style="font-size:0.7rem;">任意</span>
    <% end %>
    <div class="form-text mb-1">空白の場合は雇用形態のデフォルト値を使用します。</div>
    <div class="input-group" style="max-width: 180px;">
      <%= f.number_field :daily_work_hours, class: "form-control", step: 0.25, min: 1, max: 12,
          placeholder: staff.employment_type_id.present? ?
            EmploymentType.find_by(id: staff.employment_type_id)&.daily_work_hours.to_s : "例：7.5" %>
      <span class="input-group-text">時間</span>
    </div>
  </div>

  <%= f.submit staff.new_record? ? "登録する" : "更新する", class: "btn btn-pitat w-100 rounded-pill py-2 fw-semibold" %>

<% end %>
