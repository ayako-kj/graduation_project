<% content_for :title, "スケジュール入力URL一覧 | LibShiftAI_Pitat" %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h1 class="fs-4 fw-bold mb-1">スケジュール入力URL一覧</h1>
      <p class="text-muted small mb-0">各職員に固有のURLを配布することで、ログイン不要でスケジュールを入力してもらえます。</p>
    </div>
    <div class="d-flex gap-2">
      <%= link_to combined_qrcodes_staffs_path(from: "special"), class: "btn btn-pitat rounded-pill px-4 fw-semibold" do %>
        <i class="bi bi-qr-code me-1"></i>2次元コードを一括印刷
      <% end %>
      <%= link_to special_date_qrcodes_staffs_path, class: "btn btn-outline-secondary rounded-pill px-3" do %>
        <i class="bi bi-qr-code me-1"></i>スケジュールのみ印刷
      <% end %>
      <%= link_to "← スケジュール一覧に戻る", special_dates_path, class: "btn btn-outline-secondary rounded-pill px-3" %>
    </div>
  </div>

  <div class="pitat-card p-3 mb-4 small text-muted">
    <i class="bi bi-info-circle me-1"></i>
    URLをコピーして、LINE・メール・印刷物などで各職員に配布してください。
    希望休入力と同じトークンを使用しています。URLが漏れた場合は希望休入力URL一覧ページの「再発行」ボタンで変更できます。
  </div>

  <div class="pitat-card p-0 overflow-hidden">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-4 py-3 text-muted small fw-semibold">氏名</th>
          <th class="py-3 text-muted small fw-semibold">職種</th>
          <th class="py-3 text-muted small fw-semibold">スケジュール入力URL</th>
          <th class="py-3 text-muted small fw-semibold text-center">操作</th>
        </tr>
      </thead>
      <tbody>
        <% @staffs.each do |staff| %>
          <% url = "#{@base_url}/special?token=#{staff.access_token}" %>
          <tr>
            <td class="ps-4 py-3 fw-semibold"><%= staff.name %></td>
            <td class="py-3 text-muted small"><%= staff.staff_type.name %></td>
            <td class="py-3">
              <div class="d-flex align-items-center gap-2">
                <input type="text" value="<%= url %>"
                       id="url-<%= staff.id %>"
                       class="form-control form-control-sm"
                       style="font-size:0.75rem; font-family:monospace; background:#f8f9fa;"
                       readonly>
                <button type="button"
                        onclick="copyUrl(<%= staff.id %>)"
                        class="btn btn-sm btn-outline-secondary rounded-pill px-3 text-nowrap"
                        id="copy-btn-<%= staff.id %>">
                  <i class="bi bi-clipboard me-1"></i>コピー
                </button>
              </div>
            </td>
            <td class="py-3 pe-4 text-center">
              <%= button_to "再発行",
                  regenerate_token_staff_path(staff),
                  method: :post,
                  data: { turbo_confirm: "#{staff.name}のURLを再発行しますか？\n古いURLは使えなくなります。" },
                  class: "btn btn-sm btn-outline-danger rounded-pill px-3" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<script>
  function copyUrl(staffId) {
    const input = document.getElementById("url-" + staffId);
    const btn   = document.getElementById("copy-btn-" + staffId);
    navigator.clipboard.writeText(input.value).then(function() {
      btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>コピーしました';
      btn.classList.replace("btn-outline-secondary", "btn-success");
      setTimeout(function() {
        btn.innerHTML = '<i class="bi bi-clipboard me-1"></i>コピー';
        btn.classList.replace("btn-success", "btn-outline-secondary");
      }, 2000);
    });
  }
</script>
