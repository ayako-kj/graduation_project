<% content_for :title, "職員一覧 | LibShiftAI_Pitat" %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h1 class="fs-4 fw-bold mb-0">職員一覧</h1>
    <%= link_to "＋ 職員を登録する", new_staff_path, class: "btn btn-pitat rounded-pill px-4" %>
  </div>

  <% if @staffs.empty? %>
    <div class="pitat-card p-5 text-center text-muted">
      <i class="bi bi-people fs-1 d-block mb-3"></i>
      <p class="mb-3">まだ職員が登録されていません。</p>
      <%= link_to "職員を登録する", new_staff_path, class: "btn btn-pitat rounded-pill px-4" %>
    </div>
  <% else %>
    <div class="pitat-card p-0 overflow-hidden">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4 py-3 text-muted small fw-semibold">氏名</th>
            <th class="py-3 text-muted small fw-semibold">職種</th>
            <th class="py-3 text-muted small fw-semibold">雇用形態</th>
            <th class="py-3 text-muted small fw-semibold">週勤務日数</th>
            <th class="py-3 text-muted small fw-semibold text-center">並び替え</th>
            <th class="py-3"></th>
          </tr>
        </thead>
        <tbody>
          <% @staffs.each_with_index do |staff, i| %>
            <tr>
              <td class="ps-4 py-3 fw-semibold"><%= staff.name %></td>
              <td class="py-3"><%= staff.staff_type.name %></td>
              <td class="py-3"><%= staff.employment_type.name %></td>
              <td class="py-3"><%= staff.weekly_work_days ? "#{staff.weekly_work_days}日" : "－" %></td>
              <td class="py-3 text-center text-nowrap">
                <%= i == 0 ? tag.span("↑", class: "btn btn-sm btn-outline-secondary px-2 py-0 me-1 disabled opacity-25") :
                    button_to("↑", move_up_staff_path(staff), method: :patch, class: "btn btn-sm btn-outline-secondary px-2 py-0 me-1", form: { style: "display:inline" }) %>
                <%= i == @staffs.size - 1 ? tag.span("↓", class: "btn btn-sm btn-outline-secondary px-2 py-0 disabled opacity-25") :
                    button_to("↓", move_down_staff_path(staff), method: :patch, class: "btn btn-sm btn-outline-secondary px-2 py-0", form: { style: "display:inline" }) %>
              </td>
              <td class="py-3 pe-4 text-end">
                <%= link_to "編集", edit_staff_path(staff), class: "btn btn-sm btn-outline-secondary rounded-pill px-3 me-1" %>
                <%= link_to "削除", staff_path(staff),
                    data: { turbo_method: :delete, turbo_confirm: "#{staff.name}を削除しますか？" },
                    class: "btn btn-sm btn-outline-danger rounded-pill px-3" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
